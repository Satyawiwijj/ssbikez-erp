# Copy this file to .env and fill in real values.
# NEVER commit .env -- it is in .gitignore.

# Django
DJANGO_SECRET_KEY=your-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.onrender.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://yourdomain.onrender.com

# Database (leave blank for SQLite locally)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Email (for OTP login)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=SSBikez ERP <your@gmail.com>
